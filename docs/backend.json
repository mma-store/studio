
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Motorcycle spare parts and accessories",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "barcode": { "type": "string" },
        "purchasePrice": { "type": "number" },
        "retailPrice": { "type": "number" },
        "wholesalePrice": { "type": "number" },
        "stock": { "type": "number" },
        "description": { "type": "string" },
        "motorcycleType": { "type": "string" },
        "category": { "type": "string" },
        "storageLocation": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "isFeatured": { "type": "boolean" },
        "isSpecialOffer": { "type": "boolean" },
        "isNewArrival": { "type": "boolean" },
        "status": { "type": "string", "enum": ["available", "out_of_stock", "discontinued"] },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["name", "retailPrice", "stock", "category"]
    },
    "RepairOrder": {
      "title": "RepairOrder",
      "description": "Motorcycle workshop repair orders",
      "type": "object",
      "properties": {
        "orderNumber": { "type": "string" },
        "customerName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "bikeBrand": { "type": "string" },
        "bikeModel": { "type": "string" },
        "bikeType": { "type": "string" },
        "bikeColor": { "type": "string" },
        "plateNumber": { "type": "string" },
        "engineNumber": { "type": "string" },
        "mileage": { "type": "number" },
        "problemDescription": { "type": "string" },
        "technicianNotes": { "type": "string" },
        "status": { "type": "string", "enum": ["received", "inspection", "waiting_parts", "in_progress", "quality_check", "ready", "delivered", "cancelled"] },
        "technicianId": { "type": "string" },
        "receiveDate": { "type": "number" },
        "expectedDeliveryDate": { "type": "number" },
        "partsUsed": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            }
          } 
        },
        "laborCost": { "type": "number" },
        "additionalCharges": { "type": "number" },
        "discount": { "type": "number" },
        "totalAmount": { "type": "number" },
        "images": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      }
    },
    "Category": {
      "title": "Category",
      "description": "Product categories",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "itemsCount": { "type": "number" },
        "image": { "type": "string" }
      }
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Extended user information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "sales_employee", "workshop_technician", "warehouse_employee", "retail_customer", "wholesale_customer"] },
        "phoneNumber": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "Customer orders",
      "type": "object",
      "properties": {
        "orderNumber": { "type": "string" },
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "deliveryMethod": { "type": "string", "enum": ["delivery", "pickup"] },
        "address": { "type": "string" },
        "landmark": { "type": "string" },
        "items": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "preparing", "ready", "shipped", "delivered", "cancelled"] },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/products/{productId}": { "schema": "Product", "description": "Collection of products" },
    "/repairOrders/{orderId}": { "schema": "RepairOrder", "description": "Collection of workshop repair orders" },
    "/categories/{categoryId}": { "schema": "Category", "description": "Collection of categories" },
    "/users/{userId}": { "schema": "UserProfile", "description": "Collection of users" },
    "/orders/{orderId}": { "schema": "Order", "description": "Collection of orders" }
  }
}
