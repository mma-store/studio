{
  "entities": {
    "Tenant": {
      "title": "Tenant",
      "description": "Store or business profile in the SaaS system",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "businessName": { "type": "string" },
        "slug": { "type": "string", "description": "Unique URL slug for the store (e.g. mma-store)" },
        "logo": { "type": "string" },
        "phone": { "type": "string" },
        "whatsapp": { "type": "string" },
        "address": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended", "expired"] },
        "subscriptionPlan": { "type": "string" },
        "createdAt": { "type": "number" },
        "settings": { "type": "object" }
      },
      "required": ["tenantId", "slug", "businessName"]
    },
    "Product": {
      "title": "Product",
      "description": "Motorcycle spare parts and accessories",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "barcode": { "type": "string" },
        "purchasePrice": { "type": "number" },
        "retailPrice": { "type": "number" },
        "wholesalePrice": { "type": "number" },
        "stock": { "type": "number" },
        "category": { "type": "string" },
        "storageLocation": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "out_of_stock", "discontinued"] }
      }
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User account information linked to a tenant",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "tenantId": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "role": { "type": "string" },
        "currentBalance": { "type": "number" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "Sales records for POS or Online Shop",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "orderNumber": { "type": "string" },
        "customerName": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/tenants/{tenantId}": { "schema": "Tenant", "description": "Tenant business configuration" },
    "/users/{userId}": { "schema": "UserProfile", "description": "Tenant-scoped user accounts" },
    "/products/{productId}": { "schema": "Product", "description": "Tenant-scoped inventory" },
    "/orders/{orderId}": { "schema": "Order", "description": "Tenant-scoped sales orders" },
    "/repairOrders/{repairId}": { "schema": "object", "description": "Workshop records" },
    "/suppliers/{supplierId}": { "schema": "object", "description": "Supplier information" },
    "/purchases/{purchaseId}": { "schema": "object", "description": "Purchase invoices" },
    "/expenses/{expenseId}": { "schema": "object", "description": "Business expenses" },
    "/cashShifts/{shiftId}": { "schema": "object", "description": "Cash register shifts" },
    "/financialTransactions/{transactionId}": { "schema": "object", "description": "Ledger for accounts" },
    "/auditLogs/{logId}": { "schema": "object", "description": "Administrative actions" },
    "/categories/{categoryId}": { "schema": "object", "description": "Product categories per tenant" },
    "/banners/{bannerId}": { "schema": "object", "description": "Store banners" },
    "/offers/{offerId}": { "schema": "object", "description": "Promotional offers" }
  }
}