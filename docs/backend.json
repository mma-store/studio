
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Motorcycle spare parts and accessories",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "barcode": { "type": "string" },
        "purchasePrice": { "type": "number" },
        "retailPrice": { "type": "number" },
        "wholesalePrice": { "type": "number" },
        "stock": { "type": "number" },
        "category": { "type": "string" },
        "storageLocation": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "out_of_stock", "discontinued"] }
      }
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Wholesale suppliers of parts",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "balance": { "type": "number", "description": "Current debt to supplier" },
        "createdAt": { "type": "number" }
      }
    },
    "PurchaseInvoice": {
      "title": "PurchaseInvoice",
      "description": "Invoice for buying inventory from suppliers",
      "type": "object",
      "properties": {
        "invoiceNumber": { "type": "string" },
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "paidAmount": { "type": "number" },
        "timestamp": { "type": "number" }
      }
    },
    "Expense": {
      "title": "Expense",
      "description": "General business expenses",
      "type": "object",
      "properties": {
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "notes": { "type": "string" },
        "employeeName": { "type": "string" },
        "timestamp": { "type": "number" }
      }
    },
    "CashShift": {
      "title": "CashShift",
      "description": "Daily cash register tracking",
      "type": "object",
      "properties": {
        "openingTime": { "type": "number" },
        "closingTime": { "type": "number" },
        "openingBalance": { "type": "number" },
        "expectedBalance": { "type": "number" },
        "actualBalance": { "type": "number" },
        "status": { "type": "string", "enum": ["open", "closed"] }
      }
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "Extended user information and financial data" },
    "/suppliers/{supplierId}": { "schema": "Supplier", "description": "Supplier information" },
    "/purchases/{purchaseId}": { "schema": "PurchaseInvoice", "description": "Purchase invoices" },
    "/receiptVouchers/{voucherId}": { "schema": "ReceiptVoucher", "description": "Payment records from customers" },
    "/paymentVouchers/{voucherId}": { "schema": "PaymentVoucher", "description": "Payment records to suppliers/others" },
    "/expenses/{expenseId}": { "schema": "Expense", "description": "Business expenses" },
    "/cashShifts/{shiftId}": { "schema": "CashShift", "description": "Cash register shifts" },
    "/financialTransactions/{transactionId}": { "schema": "FinancialTransaction", "description": "Ledger for accounts" },
    "/orders/{orderId}": { "schema": "Order", "description": "Sales orders" }
  }
}
