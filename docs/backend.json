
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Motorcycle spare parts and accessories",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "barcode": { "type": "string" },
        "purchasePrice": { "type": "number" },
        "retailPrice": { "type": "number" },
        "wholesalePrice": { "type": "number" },
        "stock": { "type": "number" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "out_of_stock", "discontinued"] }
      }
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile with financial fields",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "role": { "type": "string" },
        "currentBalance": { "type": "number", "description": "Current outstanding debt" },
        "totalPaid": { "type": "number" },
        "lastPaymentDate": { "type": "number" },
        "creditLimit": { "type": "number" }
      }
    },
    "ReceiptVoucher": {
      "title": "ReceiptVoucher",
      "description": "Customer payment record",
      "type": "object",
      "properties": {
        "voucherNumber": { "type": "string" },
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "amount": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["cash", "transfer", "check"] },
        "referenceInvoice": { "type": "string" },
        "employeeId": { "type": "string" },
        "employeeName": { "type": "string" },
        "notes": { "type": "string" },
        "timestamp": { "type": "number" }
      }
    },
    "FinancialTransaction": {
      "title": "FinancialTransaction",
      "description": "Ledger entry for all account movements",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["sale", "payment", "return", "adjustment"] },
        "amount": { "type": "number" },
        "balanceAfter": { "type": "number" },
        "referenceId": { "type": "string" },
        "description": { "type": "string" },
        "timestamp": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "Extended user information and financial data" },
    "/receiptVouchers/{voucherId}": { "schema": "ReceiptVoucher", "description": "Payment records" },
    "/financialTransactions/{transactionId}": { "schema": "FinancialTransaction", "description": "Ledger for customer accounts" },
    "/orders/{orderId}": { "schema": "Order", "description": "Sales orders" }
  }
}
